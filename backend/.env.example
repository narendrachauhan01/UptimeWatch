# Server
PORT=5001
FRONTEND_URL=http://localhost:3001

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/monitor_server_prd?retryWrites=true&w=majority&appName=Cluster0

# WhatsApp Session Path (optional - default is ../../.ww-session relative to backend)
# WA_SESSION_PATH=/home/ubuntu/server-monitor-site/.ww-session

# SMTP Email Config (Gmail)
MAIL_USER=your@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=Server Monitor <your@gmail.com>
